cat > .gitignore << 'EOF'
# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
terraform.tfstate
terraform.tfstate.backup
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Local .terraform directories
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sentitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# SSH keys
*.pem
*.key
*.pub
id_rsa
id_dsa
*.pem
my-key-pair*
*.ppk

# Sensitive files
.secrets/
credentials/
*.secret
.env
.env.local

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
desktop.ini

# IDE files
.vscode/
.idea/
*.sublime-*
.project
.classpath

# Logs
*.log
terraform.log

# Backup files
*.backup
*.bak
*.old

# Output directories
output/
dist/
build/

# Ansible
*.retry
ansible.log
EOF
