# Скопируйте в terraform.tfvars и отредактируйте

aws_region  = "us-east-1"
aws_profile = "default"

bucket_name_prefix = "myapp"
environment        = "dev"

instance_type = "t3.micro"
key_name      = "my-key-pair"  # Замените на ваше имя ключа

# Ограничьте доступ по SSH своим IP для безопасности
allowed_ssh_cidrs = ["YOUR_IP_ADDRESS/32"]  # Например: ["203.0.113.5/32"]

root_volume_size = 20

common_tags = {
  ManagedBy   = "Terraform"
  Project     = "Terraform-S3-Demo"
  Environment = "dev"
}
